generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String   @id @default(uuid())
  username       String   @unique
  password       String
  realName       String
  role           String
  idCard         String?
  phone          String?
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())

  doctorSchedules   Schedule[]        @relation("DoctorSchedules")
  patientAppointments Appointment[]   @relation("PatientAppointments")
  operatedLogs      OperationLog[]
  refundRecordsAsPatient RefundRecord[] @relation("RefundPatient")
  refundRecordsAsOperator RefundRecord[] @relation("RefundOperator")
  notifications     Notification[]
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  doctors     User[]
  schedules   Schedule[]
  appointments Appointment[]
}

model Schedule {
  id           String   @id @default(uuid())
  doctorId     String
  doctor       User     @relation("DoctorSchedules", fields: [doctorId], references: [id])
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  date         DateTime
  timeSlot     String
  maxSlots     Int
  fee          Float
  isCancelled  Boolean  @default(false)
  cancelReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())

  slotInventory SlotInventory?
  appointments  Appointment[]
  operationLogs OperationLog[]

  @@unique([doctorId, date, timeSlot])
  @@index([departmentId, date])
}

model SlotInventory {
  id             String   @id @default(uuid())
  scheduleId     String   @unique
  schedule       Schedule @relation(fields: [scheduleId], references: [id])
  totalSlots     Int
  bookedSlots    Int      @default(0)
  lockedSlots    Int      @default(0)
  availableSlots Int
  version        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())
}

model Appointment {
  id               String   @id @default(uuid())
  patientId        String
  patient          User     @relation("PatientAppointments", fields: [patientId], references: [id])
  scheduleId       String
  schedule         Schedule @relation(fields: [scheduleId], references: [id])
  departmentId     String
  department       Department @relation(fields: [departmentId], references: [id])
  status           String
  fee              Float
  queueNumber      Int?
  patientName      String?
  patientIdCard    String?
  patientPhone     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())
  checkedInAt      DateTime?
  completedAt      DateTime?

  refundRecords    RefundRecord[]
  statusLogs       StatusLog[]
  notifications    Notification[]

  @@index([patientId, createdAt])
  @@index([scheduleId, status])
}

model RefundRecord {
  id              String   @id @default(uuid())
  appointmentId   String
  appointment     Appointment @relation(fields: [appointmentId], references: [id])
  patientId       String
  patient         User     @relation("RefundPatient", fields: [patientId], references: [id])
  operatorId      String?
  operator        User?    @relation("RefundOperator", fields: [operatorId], references: [id])
  amount          Float
  reason          String
  status          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())

  @@index([appointmentId])
  @@index([patientId])
}

model StatusLog {
  id             String   @id @default(uuid())
  appointmentId  String
  appointment    Appointment @relation(fields: [appointmentId], references: [id])
  fromStatus     String?
  toStatus       String
  operatorId     String?
  reason         String?
  createdAt      DateTime @default(now())

  @@index([appointmentId, createdAt])
}

model OperationLog {
  id             String   @id @default(uuid())
  type           String
  operatorId     String
  operator       User     @relation(fields: [operatorId], references: [id])
  operatorRole   String
  targetType     String
  targetId       String?
  content        String?
  createdAt      DateTime @default(now())

  schedule Schedule? @relation(fields: [targetId], references: [id])
}

model Notification {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  appointmentId   String?
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])
  type            String
  title           String
  content         String
  status          String
  failReason      String?
  createdAt       DateTime @default(now())
  sentAt          DateTime?

  @@index([userId, createdAt])
}
